---

---
<section
  class="relative w-full h-[70vh] min-h-[420px] flex items-center justify-center animate-on-scroll"
>
  <!-- Background Image -->
  <img
    src="/recording-studio.jpg"
    alt="Recording Studio Session"
    class="absolute inset-0 w-full h-full object-cover"
  />

  <!-- Overlay -->
  <div class="absolute inset-0 bg-black/50"></div>

  <!-- Content -->
  <div class="relative z-10 text-center px-6 max-w-4xl">
    <p class="text-xs md:text-sm tracking-widest uppercase text-gray-200 mb-4">
      Mixing & Mastering
    </p>

    <h2 class="text-2xl md:text-4xl font-semibold text-white leading-tight mb-8">
      Professional Recording and Audio Production<br />
      Services for You
    </h2>

    <a
      href="/sessions"
      class="inline-block bg-gradient-to-r from-[#f1a0ec] to-[#baecfe] text-black  hover:bg-gray-200  font-semibold
             px-8 py-4 rounded-sm text-sm md:text-base
             transition-colors duration-200">
      Book Session
    </a>
  </div>
</section>
