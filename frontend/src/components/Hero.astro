            <!--Alert-->
<div
  id="homepage-alert"
  onclick="closeAlert()"
  class="fixed inset-0 z-[9999] hidden flex items-center justify-center bg-black/60 backdrop-blur-md px-4"
>

  <div
   class="relative w-full max-w-4xl bg-white rounded-2xl shadow-2xl overflow-hidden grid grid-cols-2 items-stretch min-h-[220px]"
   onclick="event.stopPropagation()"
>

    <!-- LEFT: TEXT -->
