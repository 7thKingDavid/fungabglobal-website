---
let isOpen = false;
---

<nav class="fixed top-0 left-0 w-full z-50 text-white backdrop-blur-md shadow-sm">
  <div class="max-w-7xl mx-auto flex items-center justify-between px-6 py-4">

    <!-- LOGO + BRAND -->
    <a href="/" class="flex items-center gap-2 font-bold text-lg">
      <img 
        src="/logo.png" 
        alt="FunGab Logo" 
        class="max-w-24 max-h-24 object-contain"
        width="140"
        height="140"
      />
      <span class="bg-gradient-to-r from-[#52c2eb]  via-[#635da5] to-[#f191ea]
                   bg-clip-text text-transparent hidden sm:inline">
        FunGab Global
      </span>
    </a>

    <!-- Desktop Navigation -->
    <ul class="hidden md:flex items-center gap-10 font-medium">
      <li><a href="/" class="hover:text-[#D234C7] transition-colors">Home</a></li>
      <li><a href="/about" class="hover:text-[#D234C7] transition-colors">About</a></li>
      <li><a href="/services" class="hover:text-[#D234C7] transition-colors">Services</a></li>
      <li><a href="/sessions" class="hover:text-[#D234C7] transition-colors">Sessions</a></li>
      <li><a href="/blog" class="hover:text-[#D234C7] transition-colors">Blog</a></li>
      <li><a href="/contact" class="hover:text-[#D234C7] transition-colors">Contact</a></li>
    </ul>

    <!-- Mobile Menu Icon -->
    <button 
  class="md:hidden flex flex-col gap-[5px]"
  onclick="toggleMenu()">

      <span class="w-7 h-[3px] bg-white"></span>
      <span class="w-7 h-[3px] bg-white"></span>
      <span class="w-7 h-[3px] bg-white"></span>
    </button>

  </div>

  <!-- MOBILE DROPDOWN -->
  <div id="mobileMenu" class="hidden md:hidden text-center shadow-lg border-t bg-black/95 backdrop-blur">
    <ul class="flex flex-col gap-5 px-6 py-6 text-lg font-medium">
      <li><a href="/" class="hover:text-[#D234C7] transition-colors">Home</a></li>
      <li><a href="/about" class="hover:text-[#D234C7] transition-colors">About</a></li>
      <li><a href="/services" class="hover:text-[#D234C7] transition-colors">Services</a></li>
      <li><a href="/sessions" class="hover:text-[#D234C7] transition-colors">Sessions</a></li>
      <li><a href="/blog" class="hover:text-[#D234C7] transition-colors">Blog</a></li>
      <li><a href="/contact" class="hover:text-[#D234C7] transition-colors">Contact</a></li>
    </ul>
  </div>
</nav>


<script client:load>
  window.toggleMenu = function () {
    document.getElementById("mobileMenu")?.classList.toggle("hidden");
  };
</script>
