---
const posts = [
  {
    id: 1,
    category: "News & Updates",
    title: "A Day with me at FunGab Global Studio in Northumbria",
    date: "January 11, 2026",
    comments: 0,
    image: "/blog/post-1.jpg",
    link: "/blog/a-day-at-the-studio",
  },
  {
    id: 2,
    category: "News & Updates",
    title: "How to Find Your Own Unique Voice?",
    date: "November 16, 2025",
    comments: 0,
    image: "/blog/post-2.jpg",
    link: "/blog/find-your-unique-voice",
  },
  {
    id: 3,
    category: "News & Updates",
    title: "When Should I Start Singing Songs?",
    date: "December 13, 2024",
    comments: 0,
    image: "/blog/post-3.jpg",
    link: "/blog/when-to-start-singing",
  },
];
---

<section class="py-20 px-6 md:px-16">
  <!-- Heading -->
  <div class="text-center mb-14 ">
    <p class="text-xs tracking-widest uppercase text-gray-500 mb-3">
      Read the Articles
    </p>
    <h2 class="text-3xl md:text-5xl font-extrabold">
      Recent Posts
    </h2>
  </div>

  <!-- Posts -->
  <div
    class="grid grid-cols-1 md:grid-cols-3 gap-12 max-w-7xl mx-auto"
  >
    {posts.map((post, index) => (
      <article
        class={`group reveal-item delay-${index + 1}`}
      >
        <!-- Image -->
        <a href={post.link} class="block overflow-hidden">
          <img
            src={post.image}
            alt={post.title}
            class="w-full h-[260px] object-cover transition-transform duration-300 group-hover:scale-105"
          />
        </a>

        <!-- Content -->
        <div class="mt-6">
          <p class="text-xs tracking-widest uppercase text-gray-500 mb-3">
            {post.category}
          </p>

          <h3 class="text-xl font-bold leading-snug mb-3">
            <a
              href={post.link}
              class="hover:underline underline-offset-4"
            >
              {post.title}
            </a>
          </h3>

          <p class="text-sm text-gray-400">
            {post.date} &nbsp; • &nbsp; {post.comments} Comments
          </p>
        </div>
      </article>
    ))}
  </div>

  <!-- Pagination dots (visual only for now) -->
  <div class="flex justify-center mt-16 space-x-3">
    <span class="w-2 h-2 rounded-full bg-[#cfa75e]"></span>
    <span class="w-2 h-2 rounded-full bg-gray-300"></span>
    <span class="w-2 h-2 rounded-full bg-gray-300"></span>
    <span class="w-2 h-2 rounded-full bg-gray-300"></span>
  </div>
</section>
