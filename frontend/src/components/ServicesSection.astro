---
const services = [
  {
    title: "Media",
    text: "Creative media solutions that amplify your brand message.",
    image: "/assets/services/media.jpg",
  },
  {
    title: "Marketing",
    text: "Strategic marketing campaigns built for growth and impact.",
    image: "/assets/services/marketing.jpg",
  },
  {
    title: "Photography",
    text: "Professional photography that tells compelling visual stories.",
    image: "/assets/services/photography-camera.jpg",
  },
  {
    title: "Music Production",
    text: "High-quality music production from concept to final master.",
    image: "/assets/services/music.jpg",
  },
  {
    title: "Cinematography",
    text: "Cinematic visuals crafted with precision and creativity.",
    image: "/assets/services/cinematography.jpg",
  },
  {
    title: "Live Session",
    text: "Professional music recording and live session services.",
    image: "/assets/services/live-session.jpg",
  },
];
---
<section class="py-20 px-6 md:px-16 bg-white">
  <!-- Section Header -->
  <div class="text-center max-w-4xl mx-auto mb-14 animate-on-scroll">
    <p class="text-sm tracking-widest font-semibold text-gray-500 mb-3">
      OUR SERVICES
    </p>
    <h2 class="text-3xl md:text-5xl font-extrabold leading-tight">
      Transforming Your Ideas with Our Expert Solutions
    </h2>
  </div>

  <!-- Services Grid -->
  <div
    class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-7xl mx-auto"
  >
    {services.map((service) => (
      <div
        class="relative group overflow-hidden rounded-xl shadow-lg service-card animate-on-scroll"
      >
        <!-- Image -->
        <img
          src={service.image}
          alt={service.title}
          class="w-full h-[420px] object-cover transition-transform duration-300 group-hover:scale-105"
        />

        <!-- Overlay -->
        <div
          class="absolute inset-0 bg-black/40 flex flex-col justify-end p-6"
        >
          <h3 class="text-white text-2xl font-bold mb-2">
            {service.title}
          </h3>
          <p class="text-gray-200 text-sm leading-relaxed">
            {service.text}
          </p>
        </div>
      </div>
    ))}
  </div>
</section>
