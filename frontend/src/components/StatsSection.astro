<script>
  const stats = document.querySelectorAll(".stat-number");

  const animateStats = () => {
    stats.forEach((stat) => {
      const target = Number(stat.getAttribute("data-target"));
      let count = 0;

      const updateCount = () => {
        const increment = target / 80;

        if (count < target) {
          count += increment;
          stat.textContent = Math.ceil(count).toString();
          requestAnimationFrame(updateCount);
        } else {
          if (target === 98) {
  stat.textContent = `${target}%`;
} else if (target >= 100) {
  stat.textContent = `${target}+`;
} else {
  stat.textContent = `${target}+`;
}
        }
      };

      updateCount();
    });
  };

  const observer = new IntersectionObserver(
    (entries, observer) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          animateStats();
          observer.disconnect();
        }
      });
    },
    { threshold: 0.3 }
  );

  const firstStat = document.querySelector(".stat-number");

if (firstStat) {
  observer.observe(firstStat);
}
</script>