---
// Testimonials.astro
const testimonials = [
  {
    id: 1,
    name: "Alex Johnson",
    role: "Music Producer",
    image: "/testimonials/client-1.jpg",
    text: "FunGab Global transformed my vision into reality. Their attention to detail and creative approach are unmatched. Highly recommended!",
    rating: 5
  },
  {
    id: 2,
    name: "Sarah Williams",
    role: "Brand Director",
    image: "/testimonials/client-2.jpg",
    text: "Working with FunGab Global was a game-changer for our brand. Their media solutions captured exactly what we needed.",
    rating: 5
  },
  {
    id: 3,
    name: "Marcus Chen",
    role: "Artist",
    image: "/testimonials/client-3.jpg",
    text: "The professionalism and talent at FunGab is incredible. They made me feel supported throughout the entire process.",
    rating: 5
  }
];
---

<section class="py-20 px-6 md:px-16 bg-gradient-to-b from-white to-gray-50">
  <div class="max-w-7xl mx-auto">
    <!-- Section Header -->
    <div class="text-center mb-16 animate-on-scroll">
      <p class="text-sm tracking-widest font-semibold text-gray-500 mb-3 uppercase">
        What Our Clients Say
      </p>
      <h2 class="text-3xl md:text-5xl font-extrabold leading-tight">
        Trusted by Creators & Brands
      </h2>
      <p class="text-gray-600 mt-4 max-w-2xl mx-auto">
        Hear from some of the amazing creators and brands we've had the privilege to work with
      </p>
    </div>

    <!-- Testimonials Grid -->
    <div class="grid md:grid-cols-3 gap-8">
      {testimonials.map((testimonial, index) => (
        <div 
          class={`bg-white rounded-lg p-8 shadow-md hover:shadow-xl transition-shadow animate-on-scroll`}
          style={`transition-delay: ${index * 100}ms`}
        >
          <!-- Rating -->
          <div class="flex gap-1 mb-4">
            {[...Array(testimonial.rating)].map(() => (
              <svg class="w-5 h-5 text-yellow-400 fill-current" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
            ))}
          </div>

          <!-- Text -->
          <p class="text-gray-700 mb-6 leading-relaxed italic">
            &quot;{testimonial.text}&quot;
          </p>

          <!-- Author -->
          <div class="flex items-center gap-4">
            <div class="w-12 h-12 rounded-full overflow-hidden bg-gray-300 flex-shrink-0">
              <img 
                src={testimonial.image} 
                alt={testimonial.name}
                class="w-full h-full object-cover"
              />
            </div>
            <div>
              <p class="font-bold text-gray-900">{testimonial.name}</p>
              <p class="text-sm text-gray-600">{testimonial.role}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
