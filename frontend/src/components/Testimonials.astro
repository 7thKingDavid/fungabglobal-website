---
// Testimonials.astro
const testimonials = [
  {
    id: 1,
    name: "Olufunmi Adejumo",
    role: "Gospel Artist & Performer",
    image: "/assets/services/Olufunmi Adejumo.png",
    text: "FunGab Global handled my live sessions with absolute professionalism. The sound quality and stage setup were perfect. They truly understand artists.",
    rating: 5
  },
  {
    id: 2,
    name: "King Ajidara",
    role: "Afrobeat Artist",
    image: "/assets/services/kingajidarapng.png",
    text: "Working with FunGab for my music production and video shoots was a game changer. Their creativity and attention to detail brought my vision to life perfectly.",
    rating: 5
  },
  {
    id: 3,
    name: "Elijah EniOlorunfe Osobe",
    role: "Worship Leader & Recording Artist",
    image: "/assets/services/Elijah EniOlorunfe Osobe.png",
    text: "The team at FunGab Global are exceptional. From recording to live sound engineering, they delivered top quality every time. Highly recommended!",
    rating: 5
  }
];
---

<section class="py-20 px-6 md:px-16 bg-gradient-to-b from-white to-gray-50">
  <div class="max-w-7xl mx-auto">
    <!-- Section Header -->
    <div class="text-center mb-16 animate-on-scroll">
      <p class="text-sm tracking-widest font-semibold text-gray-500 mb-3 uppercase">
        What Our Clients Say
      </p>
      <h2 class="text-3xl md:text-5xl font-extrabold leading-tight">
        Trusted by Creators & Brands
      </h2>
      <p class="text-gray-600 mt-4 max-w-2xl mx-auto">
        Hear from some of the amazing creators and brands we've had the privilege to work with
      </p>
    </div>

    <!-- Testimonials Grid -->
    <div class="grid md:grid-cols-3 gap-8">
      {testimonials.map((testimonial, index) => (
        <div 
          class={`bg-white rounded-2xl p-8 shadow-md hover:shadow-xl transition-all duration-300 animate-on-scroll`}
          style={`transition-delay: ${index * 100}ms`}
        >
          <!-- Rating -->
          <div class="flex gap-1 mb-6">
            {[...Array(testimonial.rating)].map(() => (
              <span class="text-yellow-400 text-xl">★</span>
            ))}
          </div>

          <!-- Text -->
          <p class="text-gray-700 mb-8 leading-relaxed italic text-[15px]">
            &quot;{testimonial.text}&quot;
          </p>

          <!-- Author -->
          <div class="flex items-center gap-4">
            <div class="w-14 h-14 rounded-full overflow-hidden bg-gray-200 flex-shrink-0 border border-gray-100">
              <img 
                src={testimonial.image} 
                alt={testimonial.name}
                class="w-full h-full object-cover"
              />
            </div>
            <div>
              <p class="font-semibold text-gray-900">{testimonial.name}</p>
              <p class="text-sm text-gray-600">{testimonial.role}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>