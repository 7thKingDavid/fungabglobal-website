---
import BaseLayout from "../layouts/BaseLayout.astro";
import Footer from "../components/Footer.astro";

const teamMembers = [
  {
    name: "Alex Johnson",
    role: "Creative Director",
    bio: "Visionary leader with 15+ years in creative direction and brand strategy.",
    image: "/team/member-1.jpg"
  },
  {
    name: "Sarah Williams",
    role: "Head of Production",
    bio: "Experienced producer known for delivering exceptional results on high-profile projects.",
    image: "/team/member-2.jpg"
  },
  {
    name: "Marcus Chen",
    role: "Audio Engineer",
    bio: "Expert sound engineer specializing in mixing and mastering with Grammy-winning artists.",
    image: "/team/member-3.jpg"
  },
  {
    name: "Emma Roberts",
    role: "Cinematographer",
    bio: "Award-winning cinematographer bringing visual storytelling to every project.",
    image: "/team/member-4.jpg"
  }
];

const values = [
  {
    icon: "🎯",
    title: "Excellence",
    description: "We deliver premium quality in every project, with meticulous attention to detail."
  },
  {
    icon: "🤝",
    title: "Collaboration",
    description: "Your vision guides us. We work closely with clients to achieve their creative goals."
  },
  {
    icon: "💡",
    title: "Innovation",
    description: "We constantly evolve, embracing new techniques and technologies in creative production."
  },
  {
    icon: "🌟",
    title: "Authenticity",
    description: "We champion genuine creative expression and help bring authentic visions to life."
  }
];
---

<BaseLayout title="About — FunGab Global" description="Discover FunGab Global&apos;s story. A UK-based creative powerhouse transforming ideas into impactful experiences.">
  <!-- Hero Section -->
  <section class="relative min-h-[50vh] w-full text-white pt-32 pb-20 overflow-hidden">
    <img 
      src="/bg-hero.jpg" 
      alt="About FunGab Global" 
      class="absolute inset-0 w-full h-full object-cover"
    />
    <div class="absolute inset-0 bg-gradient-to-r from-black/80 via-black/70 to-black/50"></div>
    
    <div class="relative z-10 max-w-7xl mx-auto px-6 md:px-16 text-center">
      <h1 class="text-4xl md:text-5xl font-bold mb-4">About FunGab Global</h1>
      <p class="text-lg text-gray-200 max-w-2xl mx-auto">
        A creative powerhouse transforming ideas into impactful experiences through music, media, and storytelling.
      </p>
    </div>
  </section>

  <!-- Our Story Section -->
  <section class="py-20 px-6 md:px-16 bg-white">
    <div class="max-w-7xl mx-auto grid md:grid-cols-2 gap-12 items-center">
      <div class="animate-on-scroll">
        <h2 class="text-3xl md:text-4xl font-bold mb-6 text-gray-900">Our Story</h2>
        <p class="text-gray-700 mb-4 leading-relaxed">
          FunGab Global was founded on a simple belief: great creative work should be accessible to anyone with a vision. What started as a small studio in Northumbria has evolved into a full-service creative powerhouse.
        </p>
        <p class="text-gray-700 mb-4 leading-relaxed">
          Our team of passionate creators, producers, and engineers work tirelessly to deliver exceptional results across media production, music production, photography, cinematography, and marketing.
        </p>
        <p class="text-gray-700 leading-relaxed">
          Today, we&apos;re proud to partner with brands, artists, and businesses who value creativity, quality, and authentic storytelling. Our mission remains unchanged: bringing vision to life with precision and purpose.
        </p>
      </div>
      <div class="grid grid-cols-2 gap-4 animate-on-scroll">
        <img src="/work-1.jpg" alt="Studio work" class="rounded-lg hover-lift" />
        <img src="/work-2.jpg" alt="Creative session" class="rounded-lg hover-lift" />
        <img src="/assets/services/studio.jpg" alt="Equipment" class="rounded-lg hover-lift" />
        <img src="/assets/services/recording.jpg" alt="Recording" class="rounded-lg hover-lift" />
      </div>
    </div>
  </section>

  <!-- Stats Section -->
  <section class="py-16 px-6 md:px-16 bg-gradient-to-r from-[#643085] to-[#aebef1]">
    <div class="max-w-7xl mx-auto grid md:grid-cols-4 gap-8 text-center text-white">
      <div class="animate-on-scroll">
        <div class="text-5xl font-bold mb-2">500+</div>
        <p class="text-white/80">Projects Completed</p>
      </div>
      <div class="animate-on-scroll">
        <div class="text-5xl font-bold mb-2">15+</div>
        <p class="text-white/80">Years of Experience</p>
      </div>
      <div class="animate-on-scroll">
        <div class="text-5xl font-bold mb-2">50+</div>
        <p class="text-white/80">Team Members</p>
      </div>
      <div class="animate-on-scroll">
        <div class="text-5xl font-bold mb-2">100%</div>
        <p class="text-white/80">Client Satisfaction</p>
      </div>
    </div>
  </section>

  <!-- Our Values Section -->
  <section class="py-20 px-6 md:px-16 bg-white">
    <div class="max-w-7xl mx-auto">
      <h2 class="text-3xl md:text-4xl font-bold text-center mb-16">Our Core Values</h2>
      
      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8">
        {values.map((value, index) => (
          <div 
            class="text-center p-6 rounded-lg bg-gray-50 hover:shadow-lg transition-shadow animate-on-scroll"
            style={`transition-delay: ${index * 100}ms`}
          >
            <div class="text-5xl mb-4">{value.icon}</div>
            <h3 class="text-xl font-bold mb-2 text-gray-900">{value.title}</h3>
            <p class="text-gray-600">{value.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Team Section -->
  <section class="py-20 px-6 md:px-16 bg-gray-50">
    <div class="max-w-7xl mx-auto">
      <h2 class="text-3xl md:text-4xl font-bold text-center mb-16">Our Team</h2>
      
      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8">
        {teamMembers.map((member, index) => (
          <div 
            class="text-center group cursor-pointer animate-on-scroll"
            style={`transition-delay: ${index * 100}ms`}
          >
            <div class="mb-6 overflow-hidden rounded-lg h-64 bg-gray-300">
              <img 
                src={member.image}
                alt={member.name}
                class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-300"
              />
            </div>
            <h3 class="text-xl font-bold text-gray-900">{member.name}</h3>
            <p class="text-[#D234C7] font-semibold mb-3">{member.role}</p>
            <p class="text-gray-600">{member.bio}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Why Work With Us -->
  <section class="py-20 px-6 md:px-16 bg-white">
    <div class="max-w-7xl mx-auto">
      <h2 class="text-3xl md:text-4xl font-bold text-center mb-16">Why Work With Us?</h2>
      
      <div class="grid md:grid-cols-2 gap-12">
        <div class="space-y-6 animate-on-scroll">
          <div class="flex gap-4">
            <div class="w-8 h-8 rounded-full bg-[#D234C7]/20 flex items-center justify-center flex-shrink-0 mt-1">
              <span class="text-[#D234C7] font-bold">✓</span>
            </div>
            <div>
              <h3 class="font-semibold text-gray-900 mb-2">Expert Team</h3>
              <p class="text-gray-600">Professionals with years of industry experience in every creative discipline.</p>
            </div>
          </div>
          <div class="flex gap-4">
            <div class="w-8 h-8 rounded-full bg-[#D234C7]/20 flex items-center justify-center flex-shrink-0 mt-1">
              <span class="text-[#D234C7] font-bold">✓</span>
            </div>
            <div>
              <h3 class="font-semibold text-gray-900 mb-2">State-of-the-Art Equipment</h3>
              <p class="text-gray-600">Premium tools and technology to deliver professional-quality results.</p>
            </div>
          </div>
          <div class="flex gap-4">
            <div class="w-8 h-8 rounded-full bg-[#D234C7]/20 flex items-center justify-center flex-shrink-0 mt-1">
              <span class="text-[#D234C7] font-bold">✓</span>
            </div>
            <div>
              <h3 class="font-semibold text-gray-900 mb-2">Personalized Service</h3>
              <p class="text-gray-600">Tailored solutions that match your unique vision and requirements.</p>
            </div>
          </div>
        </div>

        <div class="space-y-6 animate-on-scroll">
          <div class="flex gap-4">
            <div class="w-8 h-8 rounded-full bg-[#D234C7]/20 flex items-center justify-center flex-shrink-0 mt-1">
              <span class="text-[#D234C7] font-bold">✓</span>
            </div>
            <div>
              <h3 class="font-semibold text-gray-900 mb-2">Proven Track Record</h3>
              <p class="text-gray-600">Hundreds of successful projects with satisfied clients worldwide.</p>
            </div>
          </div>
          <div class="flex gap-4">
            <div class="w-8 h-8 rounded-full bg-[#D234C7]/20 flex items-center justify-center flex-shrink-0 mt-1">
              <span class="text-[#D234C7] font-bold">✓</span>
            </div>
            <div>
              <h3 class="font-semibold text-gray-900 mb-2">Timely Delivery</h3>
              <p class="text-gray-600">We respect your deadlines and deliver quality work on schedule.</p>
            </div>
          </div>
          <div class="flex gap-4">
            <div class="w-8 h-8 rounded-full bg-[#D234C7]/20 flex items-center justify-center flex-shrink-0 mt-1">
              <span class="text-[#D234C7] font-bold">✓</span>
            </div>
            <div>
              <h3 class="font-semibold text-gray-900 mb-2">Creative Partnership</h3>
              <p class="text-gray-600">We work as an extension of your team to bring your vision to reality.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-16 px-6 md:px-16 bg-gradient-to-r from-[#D234C7] to-[#32BEF1]">
    <div class="max-w-4xl mx-auto text-center text-white">
      <h2 class="text-3xl md:text-4xl font-bold mb-4">Let&apos;s Create Something Amazing</h2>
      <p class="text-lg mb-8 text-white/90">
        Ready to bring your vision to life? Get in touch with our team today.
      </p>
      <a 
        href="/contact"
        class="inline-block px-8 py-3 rounded-full bg-white text-gray-900 font-semibold hover:bg-gray-100 transition-all"
      >
        Start Your Project
      </a>
    </div>
  </section>

  <Footer />
</BaseLayout>
