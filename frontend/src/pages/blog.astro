---
import BaseLayout from "../layouts/BaseLayout.astro";
import Footer from "../components/Footer.astro";

const posts = [
  {
    id: 1,
    slug: "a-day-at-the-studio",
    title: "A Day with me at FunGab Global Studio in Northumbria",
    category: "News & Updates",
    date: "January 11, 2026",
    author: "FunGab Team",
    excerpt: "Experience a behind-the-scenes look at our creative studio. From vocal recording to final mixing, discover what goes into creating professional music.",
    image: "/blog/blog-1.png",
    readTime: "5 min read"
  },
  {
    id: 2,
    slug: "find-your-unique-voice",
    title: "How to Find Your Own Unique Voice?",
    category: "Music Tips",
    date: "November 16, 2025",
    author: "Alex Johnson",
    excerpt: "Developing your signature sound is crucial in today&apos;s music industry. Learn techniques and strategies to discover your authentic voice.",
    image: "/blog/blog-2.png",
    readTime: "8 min read"
  },
  {
    id: 3,
    slug: "when-to-start-singing",
    title: "When Should I Start Singing Songs?",
    category: "Career Advice",
    date: "December 13, 2024",
    author: "Sarah Williams",
    excerpt: "Timing is everything in music. We break down the best age and stage to start sharing your vocal performances with the world.",
    image: "/blog/blog-3.jpg",
    readTime: "6 min read"
  },
  {
    id: 4,
    slug: "music-production-guide",
    title: "The Complete Guide to Modern Music Production",
    category: "Production",
    date: "January 5, 2026",
    author: "Marcus Chen",
    excerpt: "Master the fundamentals of music production. From recording to mastering, this comprehensive guide covers everything you need to know.",
    image: "/assets/services/music.png",
    readTime: "12 min read"
  },
  {
    id: 5,
    slug: "mixing-mistakes",
    title: "Top 10 Mixing Mistakes to Avoid",
    category: "Production",
    date: "December 28, 2025",
    author: "FunGab Team",
    excerpt: "Common mixing errors can ruin a great recording. Learn what professionals avoid and elevate your mixing skills to the next level.",
    image: "/assets/services/studio.png",
    readTime: "7 min read"
  },
  {
    id: 6,
    slug: "studio-setup-guide",
    title: "Setting Up Your Home Recording Studio",
    category: "Equipment",
    date: "December 20, 2025",
    author: "Tech Expert",
    excerpt: "Build a professional home studio on any budget. We guide you through essential equipment, room treatment, and optimization techniques.",
    image: "/assets/services/recording.png",
    readTime: "10 min read"
  }
];
---

<BaseLayout title="Blog — FunGab Global" description="Read our latest articles about music production, creative services, industry tips, and behind-the-scenes stories.">
  <!-- Hero Section -->
  <section class="relative min-h-[40vh] w-full text-white pt-32 pb-16 overflow-hidden">
    <img 
      src="/bg-hero.png" 
      alt="Blog" 
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
      decoding="sync"
    />
    <div class="absolute inset-0 bg-gradient-to-r from-black/80 via-black/70 to-black/50"></div>
    
    <div class="relative z-10 max-w-7xl mx-auto px-6 md:px-16 text-center">
      <h1 class="text-4xl md:text-5xl font-bold mb-4">FunGab Global Blog</h1>
      <p class="text-lg text-gray-200 max-w-2xl mx-auto">
        Insights, tips, and stories from our creative team. Discover the latest in music production, creative services, and industry trends.
      </p>
    </div>
  </section>

  <!-- Blog Posts Grid -->
  <section class="py-20 px-6 md:px-16 bg-white">
    <div class="max-w-7xl mx-auto">
      <!-- Featured Post -->
      {posts.length > 0 && (
        <div class="mb-16 animate-on-scroll">
          <div class="grid md:grid-cols-2 gap-8 items-center">
            <div class="overflow-hidden rounded-lg h-80">
              <img 
                src={posts[0].image}
                alt={posts[0].title}
                class="w-full h-full object-cover hover:scale-110 transition-transform duration-300"
              />
            </div>
            <div>
              <div class="flex items-center gap-3 mb-3">
                <span class="inline-block px-3 py-1 text-xs font-semibold bg-[#D234C7]/20 text-[#D234C7] rounded-full">
                  {posts[0].category}
                </span>
                <span class="text-sm text-gray-500">{posts[0].date}</span>
              </div>
              <h2 class="text-3xl font-bold mb-3 text-gray-900">{posts[0].title}</h2>
              <p class="text-gray-700 mb-4 leading-relaxed">{posts[0].excerpt}</p>
              <div class="flex items-center justify-between">
                <p class="text-sm text-gray-500">By {posts[0].author} • {posts[0].readTime}</p>
                <a 
                  href={`/blog/${posts[0].slug}`}
                  class="inline-block px-6 py-2 rounded-full bg-gradient-to-r from-[#D234C7] to-[#32BEF1] text-white font-semibold hover:opacity-90 transition-all"
                >
                  Read Full Article
                </a>
              </div>
            </div>
          </div>
        </div>
      )}

      <!-- All Posts Grid -->
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        {posts.slice(1).map((post, index) => (
          <article 
            class="group animate-on-scroll rounded-lg overflow-hidden bg-gray-50 hover:shadow-lg transition-shadow"
            style={`transition-delay: ${index * 50}ms`}
          >
            <!-- Image -->
            <div class="h-48 overflow-hidden">
              <img
                src={post.image}
                alt={post.title}
                class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-300"
              />
            </div>

            <!-- Content -->
            <div class="p-6">
              <div class="flex items-center gap-2 mb-3">
                <span class="inline-block px-2 py-1 text-xs font-semibold bg-[#D234C7]/20 text-[#D234C7] rounded-full">
                  {post.category}
                </span>
                <span class="text-xs text-gray-500">{post.date}</span>
              </div>

              <h3 class="text-xl font-bold mb-2 leading-snug text-gray-900 group-hover:text-[#D234C7] transition-colors">
                <a href={`/blog/${post.slug}`}>
                  {post.title}
                </a>
              </h3>

              <p class="text-sm text-gray-600 mb-4 leading-relaxed">
                {post.excerpt}
              </p>

              <div class="flex items-center justify-between pt-4 border-t border-gray-200">
                <p class="text-xs text-gray-500">{post.readTime}</p>
                <a 
                  href={`/blog/${post.slug}`}
                  class="text-[#D234C7] font-semibold hover:underline"
                >
                  Read →
                </a>
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Newsletter Section -->
  <section class="py-20 px-6 md:px-16 bg-gradient-to-r from-[#643085] to-[#aebef1]">
    <div class="max-w-3xl mx-auto text-center text-white">
      <h2 class="text-3xl md:text-4xl font-bold mb-4">Stay Updated</h2>
      <p class="text-lg mb-8 text-white/90">
        Subscribe to our newsletter for the latest tips, insights, and behind-the-scenes updates from FunGab Global.
      </p>
      <form class="flex flex-col md:flex-row gap-3 max-w-md mx-auto">
        <input 
          type="email"
          placeholder="Enter your email"
          required
          class="flex-1 px-4 py-3 rounded-lg bg-white/20 text-white placeholder-white/60 border border-white/30 focus:outline-none focus:ring-2 focus:ring-white/50 backdrop-blur"
        />
        <button 
          type="submit"
          class="px-8 py-3 rounded-lg bg-white text-gray-900 font-semibold hover:bg-gray-100 transition-all whitespace-nowrap"
        >
          Subscribe
        </button>
      </form>
      <p class="text-sm text-white/70 mt-4">We respect your privacy. Unsubscribe at any time.</p>
    </div>
  </section>

  <Footer />
</BaseLayout>
