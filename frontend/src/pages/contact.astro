---
import BaseLayout from "../layouts/BaseLayout.astro";
import Footer from "../components/Footer.astro";
---

<BaseLayout title="Contact — FunGab Global" description="Get in touch with FunGab Global. Send us your project details, inquiries, or booking requests.">
  <!-- Hero Section -->
  <section class="relative min-h-[40vh] w-full text-white pt-32 pb-16 overflow-hidden">
    <img 
      src="/bg-hero.jpg" 
      alt="Contact Us" 
      class="absolute inset-0 w-full h-full object-cover"
    />
    <div class="absolute inset-0 bg-gradient-to-r from-black/80 via-black/70 to-black/50"></div>
    
    <div class="relative z-10 max-w-7xl mx-auto px-6 md:px-16 text-center">
      <h1 class="text-4xl md:text-5xl font-bold mb-4">Get In Touch</h1>
      <p class="text-lg text-gray-200 max-w-2xl mx-auto">
        We&apos;d love to hear about your project. Let&apos;s collaborate and create something extraordinary.
      </p>
    </div>
  </section>

  <!-- Contact Section -->
  <section class="py-20 px-6 md:px-16 bg-white">
    <div class="max-w-7xl mx-auto grid md:grid-cols-3 gap-12">
      
      <!-- Contact Info -->
      <div class="md:col-span-1 animate-on-scroll">
        <h2 class="text-2xl font-bold mb-8 text-gray-900">Contact Information</h2>
        
        <!-- Email -->
        <div class="mb-8">
          <div class="flex items-center gap-4 mb-3">
            <div class="w-12 h-12 rounded-full bg-gradient-to-r from-[#D234C7] to-[#32BEF1] flex items-center justify-center">
              <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
            </div>
            <h3 class="text-lg font-semibold">Email</h3>
          </div>
          <p class="text-gray-600 ml-16">
            <a href="mailto:hello@fungabglobal.co.uk" class="hover:text-[#D234C7] transition-colors">hello@fungabglobal.co.uk</a>
          </p>
        </div>

        <!-- Phone -->
        <div class="mb-8">
          <div class="flex items-center gap-4 mb-3">
            <div class="w-12 h-12 rounded-full bg-gradient-to-r from-[#D234C7] to-[#32BEF1] flex items-center justify-center">
              <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
            </div>
            <h3 class="text-lg font-semibold">Phone</h3>
          </div>
          <p class="text-gray-600 ml-16">
            <a href="tel:+441234567890" class="hover:text-[#D234C7] transition-colors">+44 (0) 1234 567890</a>
          </p>
        </div>

        <!-- Location -->
        <div class="mb-8">
          <div class="flex items-center gap-4 mb-3">
            <div class="w-12 h-12 rounded-full bg-gradient-to-r from-[#D234C7] to-[#32BEF1] flex items-center justify-center">
              <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
            </div>
            <h3 class="text-lg font-semibold">Location</h3>
          </div>
          <p class="text-gray-600 ml-16">
            FunGab Global Ent. LTD<br/>
            Northumbria, UK
          </p>
        </div>

        <!-- Hours -->
        <div>
          <div class="flex items-center gap-4 mb-3">
            <div class="w-12 h-12 rounded-full bg-gradient-to-r from-[#D234C7] to-[#32BEF1] flex items-center justify-center">
              <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            </div>
            <h3 class="text-lg font-semibold">Hours</h3>
          </div>
          <p class="text-gray-600 ml-16">
            Monday - Friday: 9:00 AM - 6:00 PM<br/>
            Saturday: 10:00 AM - 4:00 PM<br/>
            Sunday: Closed
          </p>
        </div>
      </div>

      <!-- Contact Form -->
      <div class="md:col-span-2 animate-on-scroll">
        <div id="formContainer">
          <form id="contactForm" class="space-y-6">
            <div class="grid md:grid-cols-2 gap-6">
              <div>
                <label for="name" class="block text-gray-700 font-semibold mb-2">Full Name</label>
                <input 
                  type="text" 
                  id="name" 
                  name="name" 
                  required
                  class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-[#D234C7] bg-white"
                  placeholder="Your name"
                />
              </div>
              <div>
                <label for="email" class="block text-gray-700 font-semibold mb-2">Email Address</label>
                <input 
                  type="email" 
                  id="email" 
                  name="email" 
                  required
                  class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-[#D234C7] bg-white"
                  placeholder="your@email.com"
                />
              </div>
            </div>

            <div class="grid md:grid-cols-2 gap-6">
              <div>
                <label for="phone" class="block text-gray-700 font-semibold mb-2">Phone Number</label>
                <input 
                  type="tel" 
                  id="phone" 
                  name="phone"
                  class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-[#D234C7] bg-white"
                  placeholder="+44 (0) 1234 567890"
                />
              </div>
              <div>
                <label for="service" class="block text-gray-700 font-semibold mb-2">Service Interested In</label>
                <select 
                  id="service" 
                  name="service"
                  class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-[#D234C7] bg-white"
                >
                  <option>Select a service</option>
                  <option>Media Production</option>
                  <option>Marketing</option>
                  <option>Photography</option>
                  <option>Music Production</option>
                  <option>Cinematography</option>
                  <option>Live Sessions</option>
                  <option>Other</option>
                </select>
              </div>
            </div>

            <div>
              <label for="subject" class="block text-gray-700 font-semibold mb-2">Project Title</label>
              <input 
                type="text" 
                id="subject" 
                name="subject"
                class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-[#D234C7] bg-white"
                placeholder="Tell us about your project"
              />
            </div>

            <div>
              <label for="message" class="block text-gray-700 font-semibold mb-2">Message</label>
              <textarea 
                id="message" 
                name="message" 
                required
                rows="5"
                class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-[#D234C7] bg-white resize-none"
                placeholder="Tell us more about your project, timeline, budget, or any specific requirements..."
              ></textarea>
            </div>

            <div class="flex items-center gap-3">
              <input 
                type="checkbox" 
                id="consent" 
                name="consent" 
                required
                class="w-4 h-4 text-[#D234C7]"
              />
              <label for="consent" class="text-gray-700 text-sm">
                I agree to be contacted about my inquiry
              </label>
            </div>

            <button 
              type="submit"
              class="w-full px-6 py-3 rounded-lg bg-gradient-to-r from-[#D234C7] to-[#32BEF1] text-white font-semibold hover:opacity-90 transition-all"
            >
              Send Message
            </button>
          </form>
        </div>

        <!-- Success Message (hidden by default) -->
        <div id="successMessage" class="hidden bg-green-50 border-l-4 border-green-500 p-6 rounded-lg">
          <div class="flex items-start gap-4">
            <svg class="w-6 h-6 text-green-500 flex-shrink-0 mt-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            <div>
              <h3 class="text-green-800 font-semibold text-lg mb-1">Message Sent Successfully!</h3>
              <p class="text-green-700">Thank you for reaching out. We&apos;ll get back to you as soon as possible.</p>
              <button 
                onclick="location.reload()"
                class="mt-4 text-green-600 font-semibold hover:text-green-700"
              >
                Send Another Message
              </button>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Map Section -->
  <section class="py-20 px-6 md:px-16 bg-gray-100">
    <div class="max-w-7xl mx-auto">
      <h2 class="text-3xl font-bold text-center mb-12">Find Us</h2>
      <div class="w-full h-96 rounded-lg overflow-hidden shadow-lg">
        <iframe 
          src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2376.8574123903267!2d-1.3850989!3d54.9738847!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x487e700c0000007f%3A0x0!2sNorthumbria%2CUK!5e0!3m2!1sen!2suk!4v1704067200000" 
          width="100%" 
          height="100%" 
          style="border:0;" 
          allowfullscreen="" 
          loading="lazy" 
          referrerpolicy="no-referrer-when-downgrade">
        </iframe>
      </div>
    </div>
  </section>

  <Footer />

  <script client:load>
    const contactForm = document.getElementById('contactForm');
    const formContainer = document.getElementById('formContainer');
    const successMessage = document.getElementById('successMessage');

    contactForm?.addEventListener('submit', async (e) => {
      e.preventDefault();
      
      // Get form data
      const formData = new FormData(contactForm);
      const data = Object.fromEntries(formData);
      
      // Simulate form submission (in real app, would send to backend)
      console.log('Form data:', data);
      
      // Show success message
      formContainer.classList.add('hidden');
      successMessage.classList.remove('hidden');
      
      // Scroll to success message
      successMessage.scrollIntoView({ behavior: 'smooth', block: 'start' });
    });
  </script>
</BaseLayout>
