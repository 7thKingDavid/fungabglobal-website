---
import BaseLayout from "../layouts/BaseLayout.astro";
import Footer from "../components/Footer.astro";
---

<BaseLayout title="Terms of Service — FunGab Global" description="FunGab Global terms of service. Read our terms and conditions for using our services.">
  <!-- Hero Section -->
  <section class="relative min-h-[40vh] w-full text-white pt-32 pb-16 overflow-hidden bg-gradient-to-r from-black/90 via-black/80 to-black/70">
    <div class="relative z-10 max-w-7xl mx-auto px-6 md:px-16">
      <h1 class="text-4xl md:text-5xl font-bold mb-4">Terms of Service</h1>
      <p class="text-lg text-gray-200">Last updated: January 2024</p>
    </div>
  </section>

  <!-- Content Section -->
  <section class="py-20 px-6 md:px-16 bg-white">
    <div class="max-w-4xl mx-auto prose prose-lg">
      <h2 class="text-3xl font-bold mb-6 text-gray-900">Agreement to Terms</h2>
      <p class="text-gray-700 mb-8 leading-relaxed">
        By accessing and using the FunGab Global website and services, you accept and agree to be bound by the terms and provision of this agreement. If you do not agree to abide by the above, please do not use this service.
      </p>

